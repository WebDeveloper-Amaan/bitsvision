# ── Required ──────────────────────────────────────────────────────────────────
# Local:      mongodb://127.0.0.1:27017/binary_calculator
# Production: get this from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb://127.0.0.1:27017/binary_calculator

# ── Optional (defaults shown) ─────────────────────────────────────────────────
PORT=5000

# Comma-separated list of allowed frontend origins.
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
# Both:       https://your-app.vercel.app,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# Generate a strong random secret for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=change-this-to-a-long-random-string-in-production
